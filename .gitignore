# The git working tree is this `GitHub/` folder.
#
# Patterns below target dev-time artifacts that will land inside
# `GitHub/` once you run `npm install` / `npm run build` / `npm test`
# from here. They are excluded so the public repo stays clean.

# Node toolchain
node_modules/
npm-debug.log*

# Scaffold build output and generated typings
.scaffold/
build/
typings/

# Build artifacts (XPI + auto-update manifests)
weavero-v*.xpi
update.json
update-beta.json

# Local Zotero binary path for the scaffold tester (machine-specific).
.env

# Test specs are local-only for now (item 2 in the migration plan).
# Remove this rule when test/ is published.
test/
