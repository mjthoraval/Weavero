{
  "name": "weavero",
  "version": "0.11.0-dev.39",
  "private": true,
  "description": "A Zotero plugin to make clickable links and filter your library.",
  "homepage": "https://github.com/mjthoraval/Weavero",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mjthoraval/Weavero.git"
  },
  "license": "AGPL-3.0",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "zotero-plugin test",
    "test:local": "node scripts/test-local.mjs",
    "build": "zotero-plugin build",
    "start": "zotero-plugin serve",
    "prebuild": "npm run typecheck",
    "release": "zotero-plugin release"
  },
  "config": {
    "addonName": "Weavero",
    "addonID": "weavero@mjthoraval",
    "addonRef": "weavero",
    "addonInstance": "Weavero",
    "prefsPrefix": "extensions.zotero.weavero"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "chai": "^6.2.1",
    "mocha": "^11.7.6",
    "typescript": "^6.0.3",
    "zotero-plugin-scaffold": "^0.8.6",
    "zotero-types": "^4.1.2"
  }
}
