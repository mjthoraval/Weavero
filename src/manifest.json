{
  "manifest_version": 2,
  "name": "Weavero",
  "version": "0.10.0",
  "description": "A Zotero plugin to make clickable links and filter your library.",
  "author": "mjthoraval",
  "homepage_url": "https://github.com/mjthoraval/Weavero",
  "applications": {
    "zotero": {
      "id": "weavero@mjthoraval",
      "update_url": "https://github.com/mjthoraval/Weavero/releases/download/release/update.json",
      "strict_min_version": "7.0",
      "strict_max_version": "10.*"
    }
  },
  "icons": {
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  }
}
